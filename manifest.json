{
  "manifest_version": 3,
  "name": "Matrix Image + Caption",
  "version": "1.0.2",
  "description": "Send image + caption as a single Matrix m.image message",
  "permissions": ["storage"],
  "host_permissions": ["https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "settings.html"
}
